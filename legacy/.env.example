# ============================================================
# Lunervia — .env.example
# 이 파일은 "공개 가능한 예시"입니다.
# 절대 실제 키/시크릿/토큰을 이 파일에 적지 마세요.
# 실제 값은 로컬 .env (gitignore 처리됨) 또는 배포 환경의 시크릿 매니저에만 둡니다.
# ============================================================

# ---- 공개 가능한 값 (프론트엔드에 노출돼도 안전한 메타 정보) ----
PUBLIC_SITE_NAME=Lunervia
PUBLIC_SITE_URL=https://example.com
PUBLIC_DEFAULT_LANG=ko

# ---- 백엔드 전용 (절대 프론트엔드 코드에 import 하지 말 것) ----
# 아래 값들은 placeholder 입니다. 실제 키는 서버 환경변수로만 주입하세요.
SECRET_API_KEY=replace_with_server_only_value
SECRET_DB_URL=postgres://user:password@host:5432/dbname
SECRET_MAIL_PASSWORD=replace_with_server_only_value

# ---- 외부 서비스 키 (실제 값은 절대 커밋 금지) ----
# OPENAI_API_KEY=sk-...   (X — 프론트엔드 노출 금지)
# SUPABASE_SERVICE_ROLE_KEY=...   (X — 프론트엔드 노출 금지)
# FIREBASE_ADMIN_KEY=...   (X — 프론트엔드 노출 금지)
# STRIPE_SECRET_KEY=sk_live_...   (X — 프론트엔드 노출 금지)

# 민감한 API 요청은 반드시:
#  - 서버리스 함수 (Vercel/Netlify Functions, Cloudflare Workers 등)
#  - 자체 백엔드 (Node, Python 등)
# 에서 환경변수로 읽어 처리하세요.
